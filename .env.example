# Target Cafe (from URL: https://cafe.naver.com/{CAFE_NAME})
CAFE_NAME=joonggonara

# Board/Menu ID (from URL: menuid=N)
MENU_ID=335

# Collection Settings
MAX_PAGES=1          # default: 1
OUTPUT_FORMAT=md     # csv, json, xlsx, md (default: md)
OUTPUT_DIR=./data

# Delays (seconds) between requests (default: 2.0-5.0)
MIN_DELAY=2.0
MAX_DELAY=5.0